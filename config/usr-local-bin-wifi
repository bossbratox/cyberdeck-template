#!/bin/bash
# Deploy to: /usr/local/bin/wifi on Pi
#
# Then make executable:
#   sudo chmod +x /usr/local/bin/wifi
#
# What this does:
#   Launches the cyberdeck WiFi manager TUI.
#   Replaces whiptail with native curses for F-key, arrow, and touch support.

# Reset to terminal theme on exit (candy pink bg + white fg).
trap 'printf "\e[0m\e[47;97m\e[2J\e[H"' EXIT

[ -n "$FBTERM_ACTIVE" ] && export TERM=fbterm
export PYTHONPATH=/opt/cyberdeck-shared

exec python3 /opt/cyberdeck-wifi/wifi_tui.py "$@"
